{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@ai-coding/shared": ["ai-system/shared/event-types.ts"],
      "@ai-coding/pipeline": ["packages/pipeline/src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": ["ai-system/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
